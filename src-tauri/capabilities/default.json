{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for widget and main windows",
  "windows": ["widget", "main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "opener:default",
    "store:default"
  ]
}
