{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "A股盯盘助手",
  "version": "0.1.0",
  "identifier": "com.astock.monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "A股盯盘",
        "width": 360,
        "height": 520,
        "minWidth": 280,
        "minHeight": 360,
        "alwaysOnTop": true,
        "resizable": true,
        "center": false,
        "x": 40,
        "y": 80
      },
      {
        "label": "main",
        "title": "A股盯盘助手",
        "width": 1140,
        "height": 740,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "A股桌面盯盘助手",
    "longDescription": "实时查看自选股涨跌、风险与机会点，支持小窗与大窗双模式。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    }
  }
}
